<%# locals: (guessed_person:, todays_person:, nb_tries:) %>

<%= turbo_stream.prepend "guesses", partial: "people/person", locals: { person: guessed_person, todays: todays_person } %>

<% if guessed_person == todays_person %>
  <%= turbo_stream.update "congrats-div" do %>
    <%= render partial: "game/congrats", locals: { todays: todays_person, nb_tries: nb_tries } %>
  <% end %>

  <%= turbo_stream.remove "guessForm" %>
<% end %>